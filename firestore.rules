rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Whitelisted admin UID (Google sign-in: ryanjhider@gmail.com)
    // Using UID instead of email avoids casing / token normalization edge cases.
    function isAdmin() {
      return request.auth != null
        && request.auth.uid == 'xfLGmCokx6OdOWJVUdIAJ6pSdHw1';
    }

    // ===== PROJECTS =====
    // Public read (filtered by status on client).
    // Only admin can write.
    match /projects/{projectId} {
      allow read: if true;

      allow create: if isAdmin()
        && request.resource.data.id == projectId
        && request.resource.data.keys().hasAll(['id', 'title'])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200
        && request.resource.data.size < 1048576;

      allow update: if isAdmin()
        && request.resource.data.id == projectId
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200
        && request.resource.data.size < 1048576;

      allow delete: if isAdmin();
    }

    // ===== PROFILE =====
    // Public read, admin-only write.
    match /profile/{profileId} {
      allow read: if true;

      allow write: if isAdmin()
        && profileId == 'main'
        && request.resource.data.size < 1048576;
    }

    // ===== EVERYTHING ELSE =====
    // Deny by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
